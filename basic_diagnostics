// ─── STATE ───────────────────────────────────────────────────────────────────
let scores = [0, 0];
let currentTurn = 0; // 0 = P1, 1 = P2
let deckState = {};   // { catId: { remaining: [...], used: 0 } }
let currentQ = null;
let currentCatId = null;
let refShowing = false;
let totalQ = 0;
let answeredQ = 0;

function initState() {
  scores = [0, 0];
  currentTurn = 0;
  deckState = {};
  answeredQ = 0;
  totalQ = 0;
  CATEGORIES.forEach(cat => {
    const shuffled = [...cat.questions].sort(() => Math.random() - 0.5);
    deckState[cat.id] = { remaining: shuffled, used: 0, total: shuffled.length };
    totalQ += shuffled.length;
  });
}

// ─── RENDER ──────────────────────────────────────────────────────────────────
function renderDecks() {
  const grid = document.getElementById('deck-grid');
  grid.innerHTML = '';
  CATEGORIES.forEach(cat => {
    const state = deckState[cat.id];
    const empty = state.remaining.length === 0;
    const slot = document.createElement('div');
    slot.className = 'deck-slot' + (empty ? ' empty' : '');
    slot.dataset.catId = cat.id;

    const dotCount = Math.min(state.total, 5);
    let dots = '';
    for (let i = 0; i < dotCount; i++) {
      const isFilled = i < Math.min(state.remaining.length, dotCount);
      dots += `<div class="deck-dot ${isFilled ? 'filled' : 'used'}"></div>`;
    }

    slot.innerHTML = `
      ${!empty ? '<div class="stack-ghost2"></div><div class="stack-ghost"></div>' : ''}
      <div class="deck-card-face">
        <div class="deck-icon">${cat.icon}</div>
        <div class="deck-name">${cat.name}</div>
        <div class="deck-footer">
          <span class="deck-count">${empty ? 'Complete' : state.remaining.length + ' left'}</span>
          <div class="deck-dot-row">${dots}</div>
        </div>
      </div>
    `;
    if (!empty) {
      slot.onclick = () => drawCard(cat.id);
    }
    grid.appendChild(slot);
  });
}

function updateTurnUI() {
  const p1bar = document.getElementById('p1-bar');
  const p2bar = document.getElementById('p2-bar');
  p1bar.classList.toggle('active-turn', currentTurn === 0);
  p2bar.classList.toggle('active-turn', currentTurn === 1);
  updateWinBar();
}

function updateScoreUI() {
  document.getElementById('p1-score').textContent = scores[0];
  document.getElementById('p2-score').textContent = scores[1];
  updateWinBar();
}

function updateWinBar() {
  const fill = document.getElementById('win-fill');
  const total = scores[0] + scores[1];
  if (total === 0) {
    fill.style.width = '50%';
    fill.style.background = 'linear-gradient(90deg, var(--p1), var(--p1-mid))';
  } else {
    const pct = Math.round((scores[0] / total) * 100);
    fill.style.width = pct + '%';
    if (scores[0] > scores[1]) {
      fill.style.background = 'linear-gradient(90deg, var(--p1), var(--p1-mid))';
    } else {
      fill.style.background = 'linear-gradient(90deg, var(--p1), var(--p2))';
    }
  }
}

function updateStatus() {
  const rem = totalQ - answeredQ;
  const bar = document.getElementById('status-bar');
  if (rem === 0) { bar.innerHTML = ''; return; }
  bar.innerHTML = `<strong>${rem}</strong> question${rem !== 1 ? 's' : ''} remaining across all categories`;
}

// ─── GAMEPLAY ────────────────────────────────────────────────────────────────
function drawCard(catId) {
  const state = deckState[catId];
  if (!state || state.remaining.length === 0) return;

  currentCatId = catId;
  currentQ = state.remaining.shift();
  state.used++;

  const cat = CATEGORIES.find(c => c.id === catId);
  const pName = currentTurn === 0 ? "Player 1" : "Player 2";
  const turnClass = currentTurn === 0 ? 'p1-turn' : 'p2-turn';

  // Populate stage
  document.getElementById('stage-cat').textContent = cat.name;
  document.getElementById('stage-turn').textContent = pName + "'s Turn";
  document.getElementById('stage-q').textContent = currentQ.q;
  document.getElementById('stage-answer').textContent = currentQ.a;
  document.getElementById('stage-ref').textContent = currentQ.ref;

  // Reset reveal state
  const ar = document.getElementById('answer-reveal');
  ar.classList.remove('visible');
  document.getElementById('ref-box').style.display = 'none';
  document.getElementById('ref-toggle').textContent = '📄 Show Reference';
  refShowing = false;
  document.getElementById('pre-reveal-btns').style.display = '';

  // Update turn class on card
  const card = document.getElementById('stage-card-inner');
  card.classList.remove('p1-turn', 'p2-turn');
  card.classList.add(turnClass);

  // Show stage
  const stage = document.getElementById('question-stage');
  stage.classList.remove('visible');
  void stage.offsetWidth; // reflow for animation replay
  stage.classList.add('visible');

  // Update phase label
  document.getElementById('phase-text').textContent = `${pName} is answering · ${cat.name}`;

  renderDecks();
  updateStatus();

  // Scroll to question
  setTimeout(() => stage.scrollIntoView({ behavior: 'smooth', block: 'nearest' }), 50);
}

function revealAnswer() {
  document.getElementById('answer-reveal').classList.add('visible');
  document.getElementById('pre-reveal-btns').style.display = 'none';
}

function toggleRef() {
  refShowing = !refShowing;
  document.getElementById('ref-box').style.display = refShowing ? 'block' : 'none';
  document.getElementById('ref-toggle').textContent = refShowing ? '📄 Hide Reference' : '📄 Show Reference';
}

function award(player) {
  // player: 0=P1, 1=P2, -1=nobody
  if (player === 0) {
    scores[0]++;
    showToast('✓ Player 1 — correct!');
  } else if (player === 1) {
    scores[1]++;
    showToast('✓ Player 2 — correct!');
  } else {
    showToast('No points awarded');
  }

  answeredQ++;
  updateScoreUI();

  // Advance turn (always alternates after each question)
  currentTurn = 1 - currentTurn;
  updateTurnUI();

  // Hide stage
  document.getElementById('question-stage').classList.remove('visible');
  document.getElementById('phase-text').textContent = 'Pick a category to draw a question';
  currentQ = null;

  // Check game over
  const allEmpty = CATEGORIES.every(cat => deckState[cat.id].remaining.length === 0);
  if (allEmpty) {
    setTimeout(showWinner, 500);
  }
}

function showWinner() {
  const overlay = document.getElementById('winner-overlay');
  const nameEl = document.getElementById('winner-name');
  const subEl = document.getElementById('winner-sub');
  document.getElementById('wscoreP1').textContent = scores[0];
  document.getElementById('wscoreP2').textContent = scores[1];

  if (scores[0] > scores[1]) {
    nameEl.textContent = 'Player 1 Wins!';
    nameEl.className = 'p1w';
    document.getElementById('winner-crown').textContent = '🏆';
    subEl.textContent = `Player 1 answered ${scores[0]} of ${totalQ} questions correctly.`;
  } else if (scores[1] > scores[0]) {
    nameEl.textContent = 'Player 2 Wins!';
    nameEl.className = 'p2w';
    document.getElementById('winner-crown').textContent = '🏆';
    subEl.textContent = `Player 2 answered ${scores[1]} of ${totalQ} questions correctly.`;
  } else {
    nameEl.textContent = "It's a Tie!";
    nameEl.className = 'tie';
    document.getElementById('winner-crown').textContent = '🤝';
    subEl.textContent = `Both players answered ${scores[0]} questions correctly. Well played!`;
  }
  overlay.classList.add('visible');
}

function resetGame() {
  document.getElementById('winner-overlay').classList.remove('visible');
  document.getElementById('question-stage').classList.remove('visible');
  document.getElementById('phase-text').textContent = 'Pick a category to draw a question';
  document.getElementById('status-bar').innerHTML = '';
  currentQ = null;
  initState();
  updateScoreUI();
  updateTurnUI();
  renderDecks();
  updateStatus();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2000);
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
initState();
updateScoreUI();
updateTurnUI();
renderDecks();
updateStatus();
</script>
